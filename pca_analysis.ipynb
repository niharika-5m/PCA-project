import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# Sample dataset (you can replace this with CSV)
data = {
    "Age": [19, 21, 20, 23, 31, 22, 35, 23, 64, 30],
    "Income": [15, 15, 16, 16, 17, 17, 18, 18, 19, 19],
    "SpendingScore": [39, 81, 6, 77, 40, 76, 6, 94, 3, 72]
}

df = pd.DataFrame(data)

# Step 1: Mean Centering
X = df.values
X_meaned = X - np.mean(X, axis=0)

# Step 2: Covariance Matrix
cov_matrix = np.cov(X_meaned, rowvar=False)

# Step 3: Eigenvalues & Eigenvectors
eigenvalues, eigenvectors = np.linalg.eigh(cov_matrix)

# Step 4: Sort Eigenvalues
sorted_index = np.argsort(eigenvalues)[::-1]
sorted_eigenvectors = eigenvectors[:, sorted_index]

# Step 5: Select top 2 components
eigenvector_subset = sorted_eigenvectors[:, 0:2]

# Step 6: Transform Data
X_reduced = np.dot(X_meaned, eigenvector_subset)

# Convert to DataFrame
reduced_df = pd.DataFrame(X_reduced, columns=["PC1", "PC2"])

# Step 7: Visualization
plt.scatter(reduced_df["PC1"], reduced_df["PC2"])
plt.xlabel("Principal Component 1")
plt.ylabel("Principal Component 2")
plt.title("PCA Result (2D Projection)")
plt.show()
